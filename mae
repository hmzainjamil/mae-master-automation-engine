# ─── RAM Guard ───────────────────────────────────────────────────────────────
def _load_mac_profile() -> dict:
    """Load hardware profile (M-chip aware). Falls back to safe defaults."""
    p = Path.home() / ".claude/mac-profile.json"
    try:
        return json.loads(p.read_text())
    except Exception:
        return {"tier":"base","ram_gb":8,"p_cores":4,"e_cores":2,
                "mae":{"batch_size":4},"hermes":{"max_parallel_tasks":1,"keep_alive_min":10},
                "thermal":{"wait_threshold":65,"kill_threshold":85}}

MAC = _load_mac_profile()

def get_free_ram_gb() -> float:
    """Returns free+inactive RAM in GB (Unified Memory — same pool for CPU/GPU/NE)."""
    try:
        import re as _re, subprocess as _sp
        out = _sp.check_output(["vm_stat"], timeout=3).decode()
        free  = int(_re.search(r"Pages free:\s+(\d+)", out).group(1))
        inact = int(_re.search(r"Pages inactive:\s+(\d+)", out).group(1))
        return round((free + inact) * 4096 / 1024**3, 1)
    except Exception:
        return float(MAC["ram_gb"]) * 0.4  # assume 40% free

def ram_safe(min_gb=1.5) -> bool:
    return get_free_ram_gb() >= min_gb

def max_parallel_threads() -> int:
    """
    M-chip P-core aware batch size.
    Cloud threads (~0 RAM each) → run up to P-core count simultaneously.
    Hermes tasks (8GB RAM each) → capped separately by max_parallel_tasks.
    ALL tasks always run — this controls wave concurrency only.
    """
    # Profile-driven: M1 Pro = 6 P-cores → 6 cloud threads at once
    profile_batch = MAC.get("mae", {}).get("batch_size", 4)
    # Runtime adjustment based on free RAM (UMA pressure)
    gb = get_free_ram_gb()
    if gb >= 8.0:   return profile_batch        # full P-core count
    if gb >= 4.0:   return max(4, profile_batch // 2)
    if gb >= 2.0:   return 3
    return 2

# ─── LLM Executor ────────────────────────────────────────────────────────────
def _load_env() -> dict:
    env = dict(os.environ)
    env_file = Path.home() / ".claude/tier0.env"
    if env_file.exists():
        for line in env_file.read_text().splitlines():
            if line.startswith("export "):
                k, _, v = line[7:].partition("=")
                k = k.strip()
                v = v.strip().strip('"').strip("'")
                env[k] = v
    return env

def call_groq(prompt: str, model="llama-3.1-8b-instant") -> str:
    import urllib.request
    env = _load_env()
    key = env.get("GROQ_API_KEY", "")
    if not key:
        return "[Groq] No API key"

    payload = json.dumps({
        "model": model if model != "llama3-70b-8192" else "llama-3.3-70b-versatile",
        "messages": [{"role": "user", "content": prompt}],
        "max_tokens": 1500
    }).encode()

    req = urllib.request.Request(
        "https://api.groq.com/openai/v1/chat/completions",
        data=payload,
        headers={"Authorization": f"Bearer {key}", "Content-Type": "application/json", "User-Agent": "MAE/1.0"}
    )
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            d = json.loads(resp.read())
            return d["choices"][0]["message"]["content"]
    except Exception as e:
        return f"[Groq error] {e}"

def call_moonshot(prompt: str, model="moonshot-v1-8k") -> str:
    import urllib.request
    env = _load_env()
    key = env.get("MOONSHOT_API_KEY", "")
    if not key:
        return "[Moonshot] No API key"
    payload = json.dumps({
        "model": model,
        "messages": [{"role": "user", "content": prompt}],
        "max_tokens": 1500
    }).encode()
    req = urllib.request.Request(
        "https://api.moonshot.ai/v1/chat/completions",
        data=payload,
        headers={"Authorization": f"Bearer {key}", "Content-Type": "application/json", "User-Agent": "MAE/1.0"}
    )
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            d = json.loads(resp.read())
            return d["choices"][0]["message"]["content"]
    except Exception as e:
        return f"[Moonshot error] {e}"

def _is_billing_error(text: str) -> bool:
    t = text.lower()
    return any(s in t for s in ("quota", "insufficient balance", "exceeded", "billing", "rate limit", "limit: 0", "no endpoints"))

def call_synth(prompt: str) -> str:
    """Synthesis call — Groq 70B preferred; falls back to Moonshot 128k on rate limit."""
    out = call_groq(prompt, model="llama-3.3-70b-versatile")
    if out.startswith("[Groq error]") or "429" in out or _is_billing_error(out):
        return call_moonshot(prompt, model="moonshot-v1-128k")
    return out

def call_gemini(prompt: str) -> str:
    import urllib.request
    env = _load_env()
    key = env.get("GEMINI_API_KEY", "")
    if not key:
        return call_moonshot(prompt)  # fallback
    url = f"https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key={key}"
    payload = json.dumps({"contents": [{"parts": [{"text": prompt}]}]}).encode()
    req = urllib.request.Request(url, data=payload, headers={"Content-Type": "application/json", "User-Agent": "MAE/1.0"})
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            d = json.loads(resp.read())
            return d["candidates"][0]["content"]["parts"][0]["text"]
    except Exception as e:
        msg = str(e)
        if _is_billing_error(msg):
            return call_moonshot(prompt)  # auto-fallback on quota/billing
        return f"[Gemini error → Moonshot fallback] " + call_moonshot(prompt)

def call_deepseek(prompt: str) -> str:
    import urllib.request
    env = _load_env()
    key = env.get("DEEPSEEK_API_KEY", "")
    if not key:
        return call_groq(prompt, model="llama-3.3-70b-versatile")  # fallback for reasoning
    payload = json.dumps({
        "model": "deepseek-chat",
        "messages": [{"role": "user", "content": prompt}],
        "max_tokens": 2000
    }).encode()
    req = urllib.request.Request(
        "https://api.deepseek.com/chat/completions",
        data=payload,
        headers={"Authorization": f"Bearer {key}", "Content-Type": "application/json", "User-Agent": "MAE/1.0"}
    )
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            d = json.loads(resp.read())
            return d["choices"][0]["message"]["content"]
    except Exception as e:
        msg = str(e)
        if _is_billing_error(msg):
            # DeepSeek out of balance → use Groq 70B (best reasoning of the remaining Tier 0)
            return call_groq(prompt, model="llama-3.3-70b-versatile")
        return "[DeepSeek error → Groq-70B fallback] " + call_groq(prompt, model="llama-3.3-70b-versatile")

def call_ollama(prompt: str, model="llama3:latest") -> str:
    # Try multiple Ollama binary locations
    ollama_paths = [
        "/Applications/Ollama.app/Contents/Resources/ollama",
        "/opt/homebrew/bin/ollama",
        "/usr/local/bin/ollama",
        "ollama"
    ]
    ollama_bin = next((p for p in ollama_paths if os.path.exists(p)), "ollama")
    result = subprocess.run(
        [ollama_bin, "run", model, prompt[:500]],
        capture_output=True, text=True, timeout=90
    )
    return result.stdout.strip() or result.stderr.strip() or "[Ollama no output]"

def call_llm_burst(prompt: str) -> str:
    """Use llm-burst — the proven multi-model dispatcher."""
    safe = prompt.replace("'", "\\'")
    cmd = f"source ~/.claude/tier0.env 2>/dev/null && ~/.claude/bin/llm-burst '{safe[:400]}' 2>/dev/null"
    r = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=90)
    return r.stdout.strip() or r.stderr.strip() or "(no output)"

def call_hermes_fc(prompt: str) -> str:
    """
    Hermes partner call — routes to local qwen2.5:7b via hermes-fc.
    Used for: tool execution, structured output, file ops, code run, web.
    Hermes uses LOCAL RAM (qwen2.5:7b) — complementary to MAE cloud blast.
    Falls back to Ollama direct if hermes-fc unavailable.
    """
    hermes_fc = str(Path.home() / ".claude/bin/hermes-fc")
    hermes_bin = str(Path.home() / ".local/bin/hermes")
    ctx_file   = str(Path.home() / ".claude/mae-hermes-ctx.json")

    # Write task to shared context so Hermes can reference MAE's goal
    try:
        import json as _json
        ctx = {"task": prompt[:500], "source": "mae", "ts": datetime.now().isoformat()}
        Path(ctx_file).write_text(_json.dumps(ctx))
    except Exception:
        pass

    # Try hermes-fc first (structured / function calling mode)
    if os.path.exists(hermes_fc):
        try:
            r = subprocess.run(
                [hermes_fc, prompt[:400]],
                capture_output=True, text=True, timeout=120
            )
            out = r.stdout.strip()
            if out and not out.startswith("["):
                return f"[HERMES-FC] {out}"
        except Exception as e:
            pass

    # Try hermes chat -q (full tool-use mode)
    if os.path.exists(hermes_bin):
        try:
            r = subprocess.run(
                [hermes_bin, "chat", "-q", prompt[:400], "-Q"],
                capture_output=True, text=True, timeout=120
            )
            out = r.stdout.strip()
            if out:
                return f"[HERMES] {out}"
        except Exception as e:
            pass

    # Final fallback: Ollama direct
    return call_ollama(prompt, model="qwen2.5:7b")

