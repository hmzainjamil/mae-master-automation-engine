def is_tool_task(task: str) -> bool:
    """Detect if a subtask needs Hermes tool execution vs cloud LLM thinking."""
    t = task.lower()
    return any(kw in t for kw in TOOL_TASK_KEYWORDS)

SPECIALIST_ROLES = {
    "researcher":   "You are a research specialist. Find facts, data, and insights. Be thorough and cite specifics.",
    "strategist":   "You are a senior strategist. Think big picture, competitive positioning, and long-term impact.",
    "copywriter":   "You are an expert copywriter. Write compelling, persuasive, action-oriented content.",
    "analyst":      "You are a data analyst. Break down metrics, ROI, conversion rates, and measurable outcomes.",
    "tactician":    "You are an implementation tactician. Give step-by-step actionable execution plans.",
    "critic":       "You are a constructive critic. Find weaknesses, risks, and gaps in the approach.",
    "optimizer":    "You are an optimization expert. Find efficiencies, cost savings, and performance gains.",
    # Hermes partner role — local tool execution, zero cloud cost
    "executor":     "You are Hermes, a local AI agent with 30+ tools. Execute tasks using file, shell, web, code, and memory tools. Return concrete results.",
}

def run_specialist_agent(role: str, task: str, goal_context: str) -> dict:
    """Run a single specialist agent on a specific task.
    executor role → Hermes (local tools, qwen2.5:7b)
    all other roles → Tier-0 cloud LLMs (zero local RAM)
    """
    system = SPECIALIST_ROLES.get(role, "You are a helpful expert.")
    prompt = f"Context: {goal_context[:200]}\n\nYour task ({role}): {task}"

    role_model = {
        "researcher": call_gemini,      # Gemini: research + long context
        "strategist": call_deepseek,    # DeepSeek: reasoning
        "copywriter": call_groq,        # Groq: fastest for creative/copy
        "analyst":    call_deepseek,    # DeepSeek: analytical precision
        "tactician":  call_groq,        # Groq: fast execution plans
        "critic":     call_gemini,      # Gemini: broad critique
        "optimizer":  call_llm_burst,   # llm-burst: best model wins
        # ↓ Hermes partner — local tool execution, cloud-independent
        "executor":   call_hermes_fc,   # Hermes: qwen2.5:7b + 30 tools, zero API cost
    }
    fn = role_model.get(role, call_llm_burst)

    try:
        # Inject system role into prompt for LLMs that don't support system messages natively
        full_prompt = f"[ROLE: {system}]\n\n{prompt}"
        result = fn(full_prompt)
    except Exception as e:
        result = f"[{role} error] {e}"

    return {"role": role, "task": task, "output": result}

def parallel_specialist_swarm(goal: str, sub_tasks: list) -> list:
    """
    Assign each sub-task to a specialist agent.
    Parallel thread count capped by available RAM — never overloads machine.
    Returns list of results with role + output.
    """
    # ── Synergistic assignment: tool tasks → Hermes executor, thinking → cloud ──
    # Tool tasks use LOCAL RAM (Hermes/qwen2.5:7b) — zero cloud cost
    # Thinking tasks use ZERO LOCAL RAM (Groq/Gemini/DeepSeek) — pure network
    # Both categories run simultaneously — no resource conflict
    free_ram = get_free_ram_gb()
    batch_size = max_parallel_threads()

    cloud_roles = ["researcher","strategist","copywriter","analyst","tactician","critic","optimizer"]
    assignments = []
    hermes_count = 0
    for i, task in enumerate(sub_tasks):
        if is_tool_task(task) and hermes_count < 2:  # max 2 concurrent Hermes tasks (RAM guard)
            assignments.append(("executor", task))
            hermes_count += 1
            p(f"    → [executor/HERMES] {task[:60]}", "y")
        else:
            role = cloud_roles[i % len(cloud_roles)]
            assignments.append((role, task))
            p(f"    → [{role:12}/cloud] {task[:60]}", "c")

    p(f"\n  ⚡ MAE+HERMES swarm: {len(assignments)} agents | {hermes_count} Hermes (local) + {len(assignments)-hermes_count} cloud", "g")

    results = [None] * len(assignments)
    lock = threading.Lock()

    def run(idx, role, task):
        r = run_specialist_agent(role, task, goal)
        with lock:
            results[idx] = r
        icon = "🔧" if role == "executor" else "☁"
        p(f"    ✓ {icon} [{role:12}] {task[:55]}", "g")

    # Cloud tasks: batch by batch_size (no RAM concern)
    # Hermes tasks: always in separate wave (RAM guard — never concurrent with each other)
    cloud_batch = [(i, r, t) for i, (r, t) in enumerate(assignments) if r != "executor"]
    hermes_batch = [(i, r, t) for i, (r, t) in enumerate(assignments) if r == "executor"]

    # Fire cloud wave first (fast, parallel)
    for wave_start in range(0, len(cloud_batch), batch_size):
        wave = cloud_batch[wave_start:wave_start + batch_size]
        threads = [threading.Thread(target=run, args=(i, r, t)) for i, r, t in wave]
        for th in threads: th.start()
        for th in threads: th.join(timeout=60)

    # Fire Hermes tasks sequentially (each needs local RAM — no overlap)
    for i, r, t in hermes_batch:
        run(i, r, t)

    return [r for r in results if r]

SYNTHESIZE_PROMPT = """You are a senior expert synthesizer. Multiple AI agents worked on this goal in parallel.
Combine their outputs into ONE definitive, high-quality, actionable result.
Remove duplication. Keep the best insights from each. Structure clearly.

Goal: {goal}

Agent outputs:
{outputs}

Produce the FINAL synthesized output now. Be comprehensive but concise."""

def multi_agent_run(goal: str) -> dict:
    """
    Phase 1: Fire goal at 3 LLMs simultaneously.
    Phase 2: Synthesize all outputs into one superior result.
    Returns: dict with per-agent outputs + final synthesis.
    """
    p(f"\n  ⚡ Phase 1: Firing {goal[:50]}... at 3 LLMs simultaneously", "g")
    results = {}
    lock = threading.Lock()

    def run_agent(name, fn, *args):
        out = fn(*args)
        with lock:
            results[name] = out
        p(f"    ✓ {name} returned {len(out)} chars", "g")

    threads = [
        threading.Thread(target=run_agent, args=("Groq/Llama3", call_groq, goal)),
        threading.Thread(target=run_agent, args=("Gemini2Flash", call_gemini, goal)),
        threading.Thread(target=run_agent, args=("DeepSeek-V3", call_deepseek, goal)),
    ]
    for t in threads:
        t.start()
    for t in threads:
        t.join(timeout=40)

    p(f"\n  ⚡ Phase 2: Synthesizing {len(results)} agent outputs into final result...", "c")
    combined = "\n\n---\n".join(f"[{name}]:\n{out[:600]}" for name, out in results.items())
    synth_prompt = SYNTHESIZE_PROMPT.format(goal=goal, outputs=combined)
    synthesis = call_synth(synth_prompt)

    return {"agents": results, "synthesis": synthesis}

# ─── Main Run Command ─────────────────────────────────────────────────────────
def cmd_run(args):
    goal = " ".join(args.goal)
    p(f"\n{'═'*70}", "b")
    p(f"  MAE RUN — Master Automation Engine  [{datetime.now().strftime('%H:%M:%S')}]", "b")
    p(f"  Goal: {goal}", "w")
    p(f"{'═'*70}\n", "b")

    if args.plan_only:
        sub_tasks = decompose_goal(goal)
        p(f"\n  Plan: {len(sub_tasks)} parallel agents would execute:", "g")
        for i, t in enumerate(sub_tasks, 1):
            p(f"  {i}. {t}", "w")
        p("\n[Plan mode — remove --plan to execute.]", "y")
        return

    t0 = time.time()

    # ════════════════════════════════════════════════════════════════════════
    # PHASE 1 — Decompose goal into specialist sub-tasks (Groq, fast)
    # ════════════════════════════════════════════════════════════════════════
    p("▸ Phase 1/4: Decomposing goal into parallel sub-tasks...", "c")
    sub_tasks = decompose_goal(goal)
    p(f"  {len(sub_tasks)} sub-tasks identified:", "g")
    for i, t in enumerate(sub_tasks, 1):
        p(f"    {i}. {t[:72]}", "w")

    # ════════════════════════════════════════════════════════════════════════
    # PHASE 2 — Specialist swarm: each sub-task → dedicated specialist agent
    #           ALL running in parallel threads simultaneously
    # ════════════════════════════════════════════════════════════════════════
    p(f"\n▸ Phase 2/4: Launching specialist agent swarm ({len(sub_tasks)} agents × parallel)...", "c")
    p(f"  Roles: researcher · strategist · copywriter · analyst · tactician · critic · optimizer", "w")
    swarm_results = parallel_specialist_swarm(goal, sub_tasks)

    # ════════════════════════════════════════════════════════════════════════
    # PHASE 3 — Cross-LLM blast: fire full goal at Groq + Gemini + DeepSeek
    #           simultaneously for additional perspectives
    # ════════════════════════════════════════════════════════════════════════
    p(f"\n▸ Phase 3/4: Cross-LLM blast (Groq + Gemini + DeepSeek in parallel)...", "c")
    p(f"  Note: cloud APIs only — zero local RAM consumption", "y")
    blast_results = {}
    blast_lock = threading.Lock()

    def blast_run(name, fn, *fn_args):
        try:
            out = fn(*fn_args) if fn_args else fn(goal)
            with blast_lock:
                blast_results[name] = out
            p(f"    ✓ {name}", "g")
        except Exception as e:
            p(f"    ✗ {name}: {e}", "r")

    # Cloud blast runs simultaneously with Hermes tool execution (Phase 2)
    # No Ollama here — Hermes executor already covered local inference in Phase 2
    p(f"    Cloud: Groq-70B + Gemini-Flash + DeepSeek-V3 (zero local RAM)", "c")
    p(f"    Local: Hermes/qwen2.5:7b already fired in Phase 2 (tool tasks)", "y")
    blast_threads = [
        threading.Thread(target=blast_run, args=("Groq-70B",    call_groq, goal, "llama-3.3-70b-versatile")),
        threading.Thread(target=blast_run, args=("Gemini-Flash", call_gemini, goal)),
        threading.Thread(target=blast_run, args=("DeepSeek-V3",  call_deepseek, goal)),
    ]
    for t in blast_threads: t.start()
    for t in blast_threads: t.join(timeout=45)

    # Pull Hermes tool results from shared context if available
    ctx_file = Path.home() / ".claude/mae-hermes-ctx.json"
    if ctx_file.exists():
        try:
            ctx = json.loads(ctx_file.read_text())
            if ctx.get("hermes_result"):
                blast_results["Hermes-Local"] = ctx["hermes_result"]
                p(f"    ✓ Hermes-Local (from shared ctx)", "g")
        except Exception:
            pass

    # ════════════════════════════════════════════════════════════════════════
    # PHASE 4 — Master synthesis: combine ALL agent outputs into ONE
    #           definitive, high-quality, production-ready result
    # ════════════════════════════════════════════════════════════════════════
    p(f"\n▸ Phase 4/4: Master synthesis — combining all agent outputs...", "c")

    all_outputs = []
    for r in swarm_results:
        all_outputs.append(f"[{r['role'].upper()} on: {r['task'][:60]}]\n{r['output'][:400]}")
    for name, out in blast_results.items():
        all_outputs.append(f"[{name}]\n{out[:400]}")

    combined = "\n\n---\n".join(all_outputs)
    synth_prompt = SYNTHESIZE_PROMPT.format(goal=goal, outputs=combined[:3000])
    synthesis = call_synth(synth_prompt)

    elapsed = round(time.time() - t0, 1)
    total_agents = len(swarm_results) + len(blast_results)

    p(f"\n{'═'*70}", "g")
    p(f"  FINAL SYNTHESIZED OUTPUT  [{total_agents} agents · {elapsed}s]", "g")
    p(f"{'═'*70}", "g")
    p(synthesis, "w")
    p(f"{'═'*70}\n", "g")

    # Save full output
    out_path = LOGS_DIR / f"mae-{datetime.now().strftime('%Y%m%d-%H%M%S')}.md"
    lines = [f"# MAE: {goal}", f"\n> {total_agents} agents · {elapsed}s\n",
             "## Final Synthesis\n", synthesis,
             "\n## Specialist Agent Outputs\n"]
    for r in swarm_results:
        lines.append(f"\n### [{r['role'].upper()}] {r['task']}\n{r['output']}")
    for name, out in blast_results.items():
        lines.append(f"\n### [{name}]\n{out}")
    out_path.write_text("\n".join(lines))
    p(f"  Full report saved → {out_path}", "y")

    # Paperclip sync
    paperclip_sync({
        "title": goal[:100], "synthesis": synthesis[:300],
        "subtasks": sub_tasks, "source": "mae",
        "agents": total_agents, "elapsed_s": elapsed,
        "timestamp": datetime.now().isoformat()
    })

    p(f"\n  ✓ {total_agents} agents deployed · {elapsed}s total · output saved", "g")

def cmd_plan(args):
    goal = " ".join(args.goal)
    p(f"\n  MAE PLAN — {goal[:60]}", "b")
    sub_tasks = decompose_goal(goal)
    p(f"\n  Execution plan ({len(sub_tasks)} parallel agents):\n", "g")
    for i, t in enumerate(sub_tasks, 1):
        # Show what agent would handle it
        result = subprocess.run([str(TCC), "add", t, "--priority", "high"],
                                capture_output=True, text=True)
        route_info = ""
        for line in result.stdout.splitlines():
            if "→" in line:
                route_info = line.split("→")[-1].strip()
        p(f"  {i:2}. [{route_info:25}] {t[:55]}", "w")
    p(f"\n  Run: mae run '{goal}' to execute", "y")

