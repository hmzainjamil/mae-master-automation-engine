        repos = reg.get("installed_repos", {})
        p(f"  Repos: {len(repos)} available", "g")

def cmd_deploy(args):
    name = args.workflow_name
    p(f"\n  MAE DEPLOY — {name}", "b")
    # Load or build workflow
    wf_path = Path.home() / f".claude/workflows/{name}.json"
    if not wf_path.exists():
        wf_path_alt = Path.home() / f".claude/workflows/{name}.json"
        if not wf_path_alt.exists():
            p(f"Workflow '{name}' not found. Available:", "r")
            for f in sorted((Path.home() / ".claude/workflows").glob("*.json")):
                p(f"  {f.stem}", "w")
            return
    p(f"  Running workflow: {wf_path}", "c")
    result = subprocess.run(
        [str(Path.home() / ".claude/bin/workflow-dag"), str(wf_path)],
        timeout=300
    )

def cmd_register(args):
    p(f"  Register resource: {args.resource_file}", "b")
    src = Path(args.resource_file)
    if not src.exists():
        p(f"File not found: {args.resource_file}", "r")
        return
    p(f"  ✓ Resource file located. Add entries to ~/.claude/tcc-routes/agent-registry.json", "g")
    p(f"  Current registry: {REGISTRY}", "c")

# ─── MAIN ─────────────────────────────────────────────────────────────────────
def main():
    parser = argparse.ArgumentParser(
        prog="mae",
        description="MAE — Master Automation Engine. Deploy everything in parallel."
    )
    sub = parser.add_subparsers(dest="cmd")

    p_run = sub.add_parser("run", help="Decompose + execute a goal using all available agents")
    p_run.add_argument("goal", nargs="+")
    p_run.add_argument("--plan-only", "-p", action="store_true")

    p_plan = sub.add_parser("plan", help="Show execution plan without firing")
    p_plan.add_argument("goal", nargs="+")

    sub.add_parser("sprint", help="Fire ALL pending TCC tasks NOW")
    sub.add_parser("daily", help="Run full daily ops automation")
    sub.add_parser("status", help="Show all active operations and resource status")

    p_deploy = sub.add_parser("deploy", help="Deploy a specific workflow")
    p_deploy.add_argument("workflow_name")

    p_reg = sub.add_parser("register", help="Register a new resource/agent")
    p_reg.add_argument("resource_file")

    args = parser.parse_args()

    dispatch = {
        "run":      cmd_run,
        "plan":     cmd_plan,
        "sprint":   cmd_sprint,
        "daily":    cmd_daily,
        "status":   cmd_status,
        "deploy":   cmd_deploy,
        "register": cmd_register,
    }

    if args.cmd in dispatch:
        dispatch[args.cmd](args)
    else:
        cmd_status(args)

if __name__ == "__main__":
    main()
