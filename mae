TOOL_TASK_KEYWORDS = [
    "execute", "run", "search", "find", "fetch", "scrape", "browse", "read file",
    "write file", "code", "script", "install", "check", "verify", "test", "deploy",
    "create file", "list", "download", "upload", "extract", "parse", "call api",
