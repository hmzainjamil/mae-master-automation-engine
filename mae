DECOMPOSE_PROMPT = """You are a task decomposer for an AI automation system.
Break the following goal into 3-7 specific executable sub-tasks.
Each sub-task should be concrete, actionable, and independently executable.
Return ONLY a JSON array of strings. No markdown, no explanation.

Goal: {goal}

Return format: ["sub-task 1", "sub-task 2", ...]"""

def decompose_goal(goal: str) -> list:
    p(f"\n▸ Decomposing goal via Groq...", "c")
    prompt = DECOMPOSE_PROMPT.format(goal=goal)
    result = call_groq(prompt, model="llama-3.1-8b-instant")
    try:
        # Extract JSON array from response
        start = result.find("[")
        end = result.rfind("]") + 1
        if start >= 0 and end > start:
            tasks = json.loads(result[start:end])
            return [t for t in tasks if isinstance(t, str)]
    except:
        pass
    # Fallback: split by newlines
    lines = [l.strip().lstrip("-•1234567890. ") for l in result.splitlines() if len(l.strip()) > 10]
    return lines[:7]

# ─── Multi-Model Parallel Execution ──────────────────────────────────────────
def parallel_llm_blast(prompt: str) -> dict:
    """Fire same prompt at all Tier 0 LLMs simultaneously, return all results."""
    results = {}
    lock = threading.Lock()

    def run(name, fn, *args):
        try:
            out = fn(*args)
            with lock:
                results[name] = out
        except Exception as e:
            with lock:
                results[name] = f"[ERROR] {e}"

    threads = [
        threading.Thread(target=run, args=("groq", call_groq, prompt)),
        threading.Thread(target=run, args=("gemini", call_gemini, prompt)),
        threading.Thread(target=run, args=("deepseek", call_deepseek, prompt)),
    ]

    for t in threads:
        t.start()
    for t in threads:
        t.join(timeout=35)

    return results

# ─── TCC Bridge ──────────────────────────────────────────────────────────────
def tcc_add_and_fire(tasks: list, priority="high") -> None:
    """Add all tasks to TCC queue and fire them in parallel."""
    task_ids = []
    for task_desc in tasks:
        result = subprocess.run(
            [str(TCC), "add"] + task_desc.split() + ["--priority", priority],
            capture_output=True, text=True
        )
        # Extract ID from output
        for line in result.stdout.splitlines():
            if "[" in line and "]" in line:
                start = line.find("[") + 1
                end = line.find("]")
                tid = line[start:end].strip()
                if len(tid) == 8:
                    task_ids.append(tid)
                    break

    if task_ids:
        # Fire all in parallel
        subprocess.run([str(TCC), "fire", "all"], capture_output=False)

def tcc_sprint() -> None:
    """Fire ALL pending TCC tasks."""
    subprocess.run([str(TCC), "fire", "all"])

# ─── Workflow Deployer ────────────────────────────────────────────────────────
def deploy_workflow(name: str, steps: list) -> str:
    wf = {
        "name": name,
        "description": f"MAE-deployed workflow: {name}",
        "steps": [
            {
                "id": f"step_{i}",
                "command": step if isinstance(step, str) else step.get("command", "echo done"),
                "depends_on": [f"step_{i-1}"] if i > 0 else []
            }
            for i, step in enumerate(steps)
        ]
    }
    wf_path = Path.home() / f".claude/workflows/{name.replace(' ','-')}.json"
    wf_path.write_text(json.dumps(wf, indent=2))

    result = subprocess.run(
        [str(Path.home() / ".claude/bin/workflow-dag"), str(wf_path)],
        capture_output=True, text=True, timeout=120
    )
    return result.stdout or result.stderr

