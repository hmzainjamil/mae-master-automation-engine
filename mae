def cmd_status(args):
    p(f"\n  MAE STATUS — {datetime.now().strftime('%H:%M:%S')}\n", "b")
    p("  ── Paperclip CEO Layer ──", "c")
    try:
        import urllib.request
        r = urllib.request.urlopen("http://127.0.0.1:3100/", timeout=3)
        p("  ✓ Paperclip running at http://127.0.0.1:3100", "g")
    except:
        p("  ✗ Paperclip not reachable", "r")

    p("\n  ── Tier 0 LLMs ──", "c")
    try:
        r = subprocess.run(["ollama", "list"], capture_output=True, text=True, timeout=5)
        models = [l.split()[0] for l in r.stdout.splitlines()[1:] if l.strip()]
        p(f"  ✓ Ollama: {', '.join(models[:3])}", "g")
